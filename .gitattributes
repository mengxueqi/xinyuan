# Normalize text files by default.
* text=auto

# Use LF for source, config, data, and documentation files.
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.csv text eol=lf
*.sql text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Keep Windows launcher scripts on CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf
*.vbs text eol=crlf

# Treat common binary formats as binary.
*.db binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.pdf binary
*.zip binary
